# =============================================================================
# .dockerignore — excluded from Docker build context
# =============================================================================

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.eggs/
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── Databases (rebuilt by generate scripts at container start if missing) ─────
*.db
*.db-shm
*.db-wal

# ── IDE / editor ──────────────────────────────────────────────────────────────
.qodo/
.vscode/
.idea/
*.code-workspace

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & reports ────────────────────────────────────────────────────────────
*.log
logs/
scripts/build_report.json
Version_*/13_Validation/validation_report.json

# ── Test-only files (not needed in production image) ─────────────────────────
tests/
test_*.py
_*.py
pytest.ini
.pytest_cache/

# ── Docker files (no need to copy into the image) ─────────────────────────────
Dockerfile
docker-compose.yml
.dockerignore
docker_build.sh
README_DOCKER.md

# ── CI / deployment ───────────────────────────────────────────────────────────
.github/
.railway/

# ── Heavy data that is regenerated inside the image by the build scripts ──────
# (Leave these in the context so Docker Stage 2 can use them if already built;
#  comment out the lines below if you prefer to ship pre-built artefacts.)
#Version_*/06_Embeddings/embeddings.json
#Version_*/12_FAISS/index.faiss
#Version_*/12_FAISS/metadata.json
