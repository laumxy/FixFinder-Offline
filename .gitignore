# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/

# Database runtime files (rebuilt from seed data on first run)
data/*.db
data/*.db-shm
data/*.db-wal

# Versioned SQLite databases (rebuilt by generate scripts)
Version_*/03_SQLite_Database/*.db
Version_*/03_SQLite_Database/*.db-shm
Version_*/03_SQLite_Database/*.db-wal

# FAISS indices (rebuilt by build_faiss_indices.py)
embeddings/index.faiss
embeddings/metadata.json
Version_*/12_FAISS/index.faiss

# Temp / scratch files (single-underscore prefix, e.g. _check_reports.py)
# Note: does NOT match __init__.py or other dunder files

# Logs
*.log
uvicorn.log

# Reports (generated at runtime)
data/reports/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Qodo
.qodo/
